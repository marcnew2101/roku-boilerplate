<?xml version="1.0" encoding="utf-8" ?>
<component name="LandingScreen" extends="BaseScreen">
    <script type="text/brightscript" uri="LandingScreen.brs" />
    <children>
        <LayoutGroup
            id="landingContent"
            layoutDirection="vert"
            horizAlignment="center"
            itemSpacings="[60]">
            <Label
                id="landingTitle"
                horizAlign="center"
                vertAlign="center"
                font="font:LargeBoldSystemFont"/>
            <LabelList
                id="landingLabelList"
                itemSize="[260, 70]"
                itemSpacing="[0, 10]"
                textHorizAlign="center"
                font="font:MediumSystemFont"
                focusedFont="font:MediumBoldSystemFont"
                vertFocusAnimationStyle="floatingFocus"/>
        </LayoutGroup>
    </children>
</component>
